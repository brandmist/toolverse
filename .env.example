# ToolVerse Environment Variables Example
# Copy this file to .env and fill in the actual values. DO NOT commit .env to GitHub.

# Example API Keys (if needed for server-side endpoints, not exposed to frontend)
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Frontend Variables (must start with VITE_)
VITE_APP_ENV=production
VITE_API_URL=https://api.toolverse.com

# Node Configuration
NODE_VERSION=20
NODE_ENV=production
